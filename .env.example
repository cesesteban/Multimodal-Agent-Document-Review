# LegalMove API - Environment Configurations Template
PROJECT_NAME="LegalMove API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# API Key Security (Optional/Required for API authentication. Set to secure string to enable, leave blank to disable)
API_KEY="super-secret-legalmove-key"

# OpenAI Credentials
OPENAI_API_KEY="sk-proj-XXXXXXXXXXXXXXXXXXXXXXXX"
OPENAI_MODEL_NAME="gpt-4o"

# Langfuse Observability Integration
LANGFUSE_PUBLIC_KEY="pk-lf-XXXXXXXXXXXXXXXXXXXXXXXX"
LANGFUSE_SECRET_KEY="sk-lf-XXXXXXXXXXXXXXXXXXXXXXXX"
LANGFUSE_HOST="https://cloud.langfuse.com"

# Secure CORS Origins (comma-separated, e.g. "http://localhost:3000,https://myclient.com")
ALLOWED_CORS_ORIGINS="*"

# Rate Limiting (maximum requests per window per IP, e.g. 10 requests per 60 seconds)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60